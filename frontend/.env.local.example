# =============================================================================
# Libre Tiles — Frontend Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.

# Django backend URL used by browser-side API calls.
# `localhost` works for desktop dev and is auto-rewritten to the current LAN
# hostname when the frontend is opened from another device.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Django backend URL used by Next.js server-side route handlers.
BACKEND_URL=http://localhost:8000

# Optional: additional dev hosts/origins allowed to load Next.js dev assets.
# Example: NEXT_DEV_ALLOWED_ORIGINS=tablet.local,192.168.1.164
# NEXT_DEV_ALLOWED_ORIGINS=

# Default AI model (provider/model format for Vercel AI Gateway)
NEXT_PUBLIC_DEFAULT_MODEL=openai/gpt-5.4

# ---------------------------------------------------------------------------
# Vercel AI Gateway (recommended — one key for all providers)
# Get your key at https://vercel.com/ai-gateway
# ---------------------------------------------------------------------------
AI_GATEWAY_API_KEY=your-vercel-ai-gateway-api-key
AI_GATEWAY_BASE_URL=https://ai-gateway.vercel.sh/v1

# ---------------------------------------------------------------------------
# Direct provider keys (fallback — used when AI_GATEWAY_API_KEY is not set)
# Only needed for local dev without Vercel AI Gateway.
# ---------------------------------------------------------------------------
# OPENAI_API_KEY=sk-...
# GOOGLE_GENERATIVE_AI_API_KEY=...
# ANTHROPIC_API_KEY=...
