# =============================================================================
# Libre Tiles — Backend Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# Django
DJANGO_SECRET_KEY='change-me-to-a-long-random-string-in-production'
DJANGO_DEBUG='true'
DJANGO_ALLOWED_HOSTS='*'

# Database
# SQLite for dev (zero config), PostgreSQL for production
DB_ENGINE='sqlite3'
# DB_ENGINE='postgresql'
# DB_NAME='libretiles'
# DB_USER='libretiles'
# DB_PASSWORD='libretiles'
# DB_HOST='localhost'
# DB_PORT='5432'

# CORS — frontend origins allowed to call this API
CORS_ALLOWED_ORIGINS='http://localhost:3000'

# Realtime / Channels
REDIS_URL='redis://127.0.0.1:6379/0'
GAME_WS_TICKET_MAX_AGE_SECONDS='60'

# AI budget defaults (passed to game context for Vercel AI Gateway)
AI_MOVE_MAX_OUTPUT_TOKENS='15000'
AI_MOVE_TIMEOUT_SECONDS='120'

# Billing / credits
DEFAULT_STARTING_CREDITS='10.00'
CREDITS_PER_USD='1'
